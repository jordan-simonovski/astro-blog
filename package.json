{
  "name": "blog",
  "version": "2.3.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro check --watch & astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "check": "astro check",
    "preview": "astro preview",
    "sync": "astro sync",
    "astro": "astro",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "prepare": "husky install",
    "lint": "eslint . && markdownlint-cli2 \"**/*.md\"",
    "lint:fix": "eslint . --fix && markdownlint-cli2 --fix \"**/*.md\"",
    "a11y": "astro build && node scripts/a11y.mjs"
  },
  "dependencies": {
    "@astro-community/astro-embed-twitter": "^0.5.11",
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/rss": "^4.0.18",
    "@giscus/react": "^3.1.0",
    "@resvg/resvg-js": "^2.6.2",
    "@vercel/analytics": "^2.0.1",
    "astro": "^6.4.8",
    "astro-expressive-code": "^0.43.1",
    "fuse.js": "^6.6.2",
    "github-slugger": "^2.0.0",
    "mdast-util-to-string": "^4.0.0",
    "reading-time": "^1.5.0",
    "remark-collapse": "^0.1.2",
    "remark-toc": "^8.0.1",
    "satori": "^0.26.0",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/react": "^5.0.7",
    "@astrojs/sitemap": "^3.7.3",
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/typography": "^0.5.20",
    "@types/github-slugger": "^2.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "astro-compress": "^2.4.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "husky": "^8.0.3",
    "lint-staged": "^17.0.7",
    "markdownlint-cli2": "^0.22.1",
    "playwright": "^1.61.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,astro,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.md": [
      "prettier --write",
      "markdownlint-cli2 --fix"
    ],
    "*.{mdx,json}": [
      "prettier --write"
    ]
  }
}
