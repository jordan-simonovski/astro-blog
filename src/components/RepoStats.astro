---
interface Props {
  language: string | null;
  stars: number;
  forks: number;
}

const { language, stars, forks } = Astro.props;

const LANGUAGE_COLORS: Record<string, string> = {
  c: "#555555",
  "c++": "#f34b7d",
  "c#": "#178600",
  css: "#563d7c",
  dockerfile: "#384d54",
  go: "#00ADD8",
  html: "#e34c26",
  java: "#b07219",
  javascript: "#f1e05a",
  kotlin: "#A97BFF",
  lua: "#000080",
  php: "#4F5D95",
  python: "#3572A5",
  ruby: "#701516",
  rust: "#dea584",
  shell: "#89e051",
  swift: "#F05138",
  typescript: "#3178c6",
  vue: "#41b883",
  astro: "#ff5a03",
};

const languageColor = language
  ? (LANGUAGE_COLORS[language.toLowerCase()] ?? "#8b949e")
  : "#8b949e";

function formatCount(n: number): string {
  if (n < 1000) return String(n);
  return `${(n / 1000).toFixed(1).replace(/\.0$/, "")}k`;
}
---

<div class="repo-stats">
  {
    language && (
      <span class="repo-stats__item">
        <span class="repo-stats__dot" style={`background:${languageColor}`} />
        {language}
      </span>
    )
  }
  <span class="repo-stats__item">
    <svg viewBox="0 0 16 16" width="16" height="16" aria-hidden="true" fill="currentColor">
      <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.751.751 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z"></path>
    </svg>
    {formatCount(stars)}
  </span>
  <span class="repo-stats__item">
    <svg viewBox="0 0 16 16" width="16" height="16" aria-hidden="true" fill="currentColor">
      <path d="M5 5.372v.878c0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75v-.878a2.25 2.25 0 1 1 1.5 0v.878a2.25 2.25 0 0 1-2.25 2.25h-1.5v2.128a2.251 2.251 0 1 1-1.5 0V8.5h-1.5A2.25 2.25 0 0 1 3.5 6.25v-.878a2.25 2.25 0 1 1 1.5 0ZM5 3.25a.75.75 0 1 0-1.5 0 .75.75 0 0 0 1.5 0Zm6.75.75a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm-3 8.75a.75.75 0 1 0-1.5 0 .75.75 0 0 0 1.5 0Z"></path>
    </svg>
    {formatCount(forks)}
  </span>
</div>

<style>
  .repo-stats {
    @apply flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-skin-base opacity-80;
  }
  .repo-stats__item {
    @apply flex items-center gap-1;
  }
  .repo-stats__item svg {
    @apply opacity-70;
  }
  .repo-stats__dot {
    @apply inline-block h-3 w-3 rounded-full;
  }
</style>
