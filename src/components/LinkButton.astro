---
export interface Props {
  href: string;
  className?: string;
  ariaLabel?: string;
  title?: string;
  disabled?: boolean;
}

const { href, className, ariaLabel, title, disabled = false } = Astro.props;
---

<a
  href={href}
  tabindex={disabled ? "-1" : "0"}
  class={`group inline-block ${disabled ? "pointer-events-none" : ""} ${className}`}
  aria-label={ariaLabel}
  title={title}
  aria-disabled={disabled}
  target="_blank"
  rel="me"
>
  <slot />
</a>

<style>
  a {
    @apply hover:text-skin-accent;
  }
</style>
