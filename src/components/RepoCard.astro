---
import { getRepoData } from "@utils/getRepoData";
import RepoStats from "@components/RepoStats.astro";

export interface Props {
  repo: string;
}

const { repo } = Astro.props;

const isValid = /^[^/\s]+\/[^/\s]+$/.test(repo.trim());

if (!isValid) {
  console.warn(
    `[RepoCard] invalid repo "${repo}"; expected "owner/name". Rendering link only.`
  );
}

const data = isValid
  ? await getRepoData(repo)
  : {
      fullName: repo,
      description: null,
      language: null,
      stars: 0,
      forks: 0,
      url: `https://github.com/${repo}`,
      parent: null,
      degraded: true,
    };

const REPO_ICON =
  "M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 0 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 1 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Zm10.5-1h-8a1 1 0 0 0-1 1v6.708A2.486 2.486 0 0 1 4.5 9h8ZM5 12.25a.25.25 0 0 1 .25-.25h3.5a.25.25 0 0 1 .25.25v3.25a.25.25 0 0 1-.4.2l-1.45-1.087a.249.249 0 0 0-.3 0L5.4 15.7a.25.25 0 0 1-.4-.2Z";
const FORK_ICON =
  "M5 5.372v.878c0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75v-.878a2.25 2.25 0 1 1 1.5 0v.878a2.25 2.25 0 0 1-2.25 2.25h-1.5v2.128a2.251 2.251 0 1 1-1.5 0V8.5h-1.5A2.25 2.25 0 0 1 3.5 6.25v-.878a2.25 2.25 0 1 1 1.5 0ZM5 3.25a.75.75 0 1 0-1.5 0 .75.75 0 0 0 1.5 0Zm6.75.75a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm-3 8.75a.75.75 0 1 0-1.5 0 .75.75 0 0 0 1.5 0Z";

const parent = data.parent;
const name = data.fullName.split("/").pop() ?? data.fullName;

const ownDescription =
  data.description && (!parent || data.description !== parent.description)
    ? data.description
    : null;

const showOwnStats =
  !data.degraded && (!parent || data.stars > 0 || data.forks > 0);
---

<div class="repo-card not-prose">
  <a class="repo-card__title" href={data.url} target="_blank" rel="noopener noreferrer">
    <svg viewBox="0 0 16 16" width="16" height="16" aria-hidden="true" fill="currentColor">
      <path d={REPO_ICON}></path>
    </svg>
    <span>{name}</span>
  </a>

  {
    parent && (
      <a
        class="repo-card__forked"
        href={parent.url}
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg viewBox="0 0 16 16" width="13" height="13" aria-hidden="true" fill="currentColor">
          <path d={FORK_ICON} />
        </svg>
        Forked from {parent.fullName}
      </a>
    )
  }

  {ownDescription && <p class="repo-card__desc">{ownDescription}</p>}

  {
    showOwnStats && (
      <RepoStats language={data.language} stars={data.stars} forks={data.forks} />
    )
  }

  {
    parent && (
      <a
        class="repo-card__quote"
        href={parent.url}
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="repo-card__quote-title">
          <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true" fill="currentColor">
            <path d={REPO_ICON} />
          </svg>
          {parent.fullName}
        </span>
        {parent.description && (
          <span class="repo-card__quote-desc">{parent.description}</span>
        )}
        <RepoStats
          language={parent.language}
          stars={parent.stars}
          forks={parent.forks}
        />
      </a>
    )
  }
</div>

<style>
  .repo-card {
    @apply my-6 rounded-md border border-skin-line bg-skin-card p-4;
  }
  .repo-card__title {
    @apply flex items-center gap-2 text-base font-semibold text-skin-accent no-underline;
  }
  .repo-card__title svg {
    @apply shrink-0 opacity-70;
  }
  .repo-card__title:hover span {
    @apply underline;
  }
  .repo-card__forked {
    @apply mt-1 flex items-center gap-1 text-xs text-skin-base no-underline opacity-60 hover:opacity-90;
  }
  .repo-card__desc {
    @apply my-2 text-sm leading-relaxed text-skin-base opacity-80;
  }
  .repo-card__quote {
    @apply mt-3 block rounded-md border border-skin-line bg-skin-fill p-3 no-underline transition-opacity hover:opacity-90;
  }
  .repo-card__quote-title {
    @apply flex items-center gap-1.5 text-sm font-semibold text-skin-accent;
  }
  .repo-card__quote-title svg {
    @apply shrink-0 opacity-70;
  }
  .repo-card__quote-desc {
    @apply mb-2 mt-1 block text-sm leading-snug text-skin-base opacity-80;
  }
</style>
