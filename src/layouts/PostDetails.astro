---
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Tag from "@components/Tag.astro";
import Datetime from "@components/Datetime";
import QuoteShare from "@components/QuoteShare.astro";
import Lightbox from "@components/Lightbox.astro";
import Comments from "@components/Comments";
import { GISCUS } from "@config";
import { render, type CollectionEntry } from "astro:content";
import slugify, { slugifyStr } from "@utils/slugify";

export interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;

const { title, author, description, ogImage, ogImageWidth, ogImageHeight, canonicalURL, pubDatetime, tags, readingTime } = post.data;

const { Content } = await render(post);

const ogUrl = new URL(
  ogImage ? ogImage : `${slugify(post.data)}.png`,
  Astro.url.origin
).href;
const pageUrl = canonicalURL
  ? new URL(canonicalURL, Astro.url.origin).href
  : Astro.url.href;
---

<Layout title={title} author={author} description={description} ogImage={ogUrl} ogImageWidth={ogImageWidth} ogImageHeight={ogImageHeight} canonicalURL={canonicalURL} readingTime={readingTime} >
  <Header />
  <div class="mx-auto flex w-full max-w-3xl justify-start px-2">
    <button
      class="focus-outline mb-2 mt-8 flex hover:opacity-75"
      onclick="history.back()"
    >
      <svg xmlns="http://www.w3.org/2000/svg"
        ><path
          d="M13.293 6.293 7.586 12l5.707 5.707 1.414-1.414L10.414 12l4.293-4.293z"
        ></path>
      </svg><span>Go back</span>
    </button>
  </div>
  <main id="main-content">
    <h1 class="post-title">{title}</h1>
    <Datetime datetime={pubDatetime} size="lg" className="my-2" readingTime={readingTime} />
    <article id="article" role="article" class="prose mx-auto mt-8 max-w-3xl">
      <Content />
    </article>
    <QuoteShare pageTitle={title} pageUrl={pageUrl} />
    <Lightbox />

    <ul class="tags-container">
      {tags.map(tag => <Tag name={slugifyStr(tag)} />)}
    </ul>

    {
      GISCUS.enabled && (
        <section class="mt-8">
          {/* giscus renders nothing on the server (it needs `document` and injects
              its own iframe at runtime). client:visible observes the island's SSR
              children to decide when to hydrate; with no children it never fires.
              client:only skips SSR and hydrates on the client. */}
          <Comments client:only="react" />
        </section>
      )
    }
  </main>
  <Footer />
</Layout>

<style>
  main {
    @apply mx-auto w-full max-w-3xl px-4 pb-12;
  }
  .post-title {
    @apply text-2xl font-semibold text-skin-accent;
  }
  .tags-container {
    @apply my-8;
  }
</style>
